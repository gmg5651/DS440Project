{
    "expo": {
        "name": "Swiftulin",
        "slug": "swiftulin",
        "version": "0.1.0",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "userInterfaceStyle": "dark",
        "scheme": "swiftulin",
        "splash": {
            "image": "./assets/splash.png",
            "resizeMode": "contain",
            "backgroundColor": "#0a0a0a"
        },
        "assetBundlePatterns": [
            "**/*"
        ],
        "ios": {
            "supportsTablet": false,
            "bundleIdentifier": "com.swiftulin",
            "infoPlist": {
                "NSMicrophoneUsageDescription": "Swiftulin needs microphone access to record your meal descriptions by voice.",
                "NSSpeechRecognitionUsageDescription": "Swiftulin uses speech recognition to transcribe your meal descriptions."
            }
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/adaptive-icon.png",
                "backgroundColor": "#0a0a0a"
            },
            "package": "com.swiftulin",
            "permissions": [
                "RECORD_AUDIO"
            ]
        },
        "web": {
            "bundler": "metro",
            "output": "static",
            "favicon": "./assets/favicon.png"
        },
        "plugins": [
            "expo-router",
            "expo-sqlite",
            [
                "expo-av",
                {
                    "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone to log meals by voice."
                }
            ]
        ],
        "experiments": {
            "typedRoutes": true
        }
    }
}