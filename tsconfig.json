{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
        "strict": true,
        "allowJs": true,
        "esModuleInterop": true,
        "jsx": "react-native",
        "lib": [
            "ESNext"
        ],
        "moduleResolution": "bundler",
        "noEmit": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "target": "ESNext",
        "paths": {
            "@/*": [
                "./src/*"
            ]
        }
    },
    "include": [
        "**/*.ts",
        "**/*.tsx",
        ".expo/types/**/*.d.ts",
        "expo-env.d.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}